{
	"name": "back",
	"private": true,
	"prisma": {
		"schema": "./prisma/schema/schema.prisma"
	},
	"scripts": {
		"dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:next\"",
		"dev:server": "PORT_BACKEND=3002 tsx watch server.ts",
		"dev:next": "NEXT_STANDALONE=true next dev --port 4500",
		"dev:all": "concurrently \"pnpm run dev:server\" \"pnpm run dev:next\"",
		"dev:turbo": "next dev --turbopack",
		"build": "next build",
		"start": "NODE_ENV=production node --import tsx ./server.ts",
		"start:next": "next start",
		"start:all": "concurrently \"pnpm start\" \"pnpm start:next\"",
		"db:push": "prisma db push",
		"db:studio": "prisma studio",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev"
	},
	"dependencies": {
		"@daily-co/daily-js": "^0.87.0",
		"@prisma/adapter-pg": "^7.4.1",
		"@prisma/client": "^7.4.1",
		"@prisma/extension-accelerate": "^3.0.1",
		"@react-email/components": "^1.0.8",
		"@react-email/render": "^2.0.4",
		"@trpc/server": "^11.10.0",
		"better-auth": "^1.4.19",
		"dompurify": "^3.3.1",
		"dotenv": "^17.3.1",
		"file-type": "^21.3.0",
		"jsdom": "^28.1.0",
		"next": "16.1.6",
		"pg": "^8.19.0",
		"prom-client": "^15.1.3",
		"rate-limiter-flexible": "^9.1.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"resend": "^6.9.2",
		"sharp": "^0.34.5",
		"socket.io": "^4.8.3"
	},
	"devDependencies": {
		"@types/jsdom": "^28.0.0",
		"@types/node": "^25.3.0",
		"@types/pg": "^8.16.0",
		"@types/react": "^19.2.14",
		"concurrently": "^9.2.1",
		"prisma": "^7.4.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"zod": "^4.3.6"
	}
}