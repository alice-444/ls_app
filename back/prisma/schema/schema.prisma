generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgres"
}

model account {
  id                     String    @id @map("_id")
  accountId              String    @unique
  email                  String?   @unique
  isEmailVerified        Boolean
  password               String?
  failedLoginAttempts    Int
  isLocked               Boolean
  lockoutTime            DateTime?
  lastLogin              DateTime
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  emailChangeToken       String?
  emailChangeNewEmail    String?
  emailChangeTimestamp   DateTime?
  passwordResetToken     String?
  passwordResetTimestamp DateTime?

  user app_user?
}

model app_user {
  id               String    @id @default(cuid())
  userId           String    @unique
  name             String
  email            String    @unique
  onboardingStep   Int       @default(0)
  role             String?
  status           String    @default("PENDING")
  deletionReason   String?
  photoUrl         String?
  displayName      String?
  bio              String?
  domain           String?
  areasOfExpertise String[]
  mentorshipTopics String[]
  qualifications   String?
  experience       String?
  socialMediaLinks Json?
  calendlyLink     String?
  isPublished      Boolean   @default(false)
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  // Relations
  account account @relation(fields: [userId], references: [accountId], onDelete: Cascade)

  reports_made     user_report[] @relation("reports_made")
  reports_received user_report[] @relation("reports_received")

  blocked_by user_block[] @relation("blocked_by")
  blocking   user_block[] @relation("blocking")

  sent_requests     user_connection[] @relation("sent_requests")
  received_requests user_connection[] @relation("received_requests")

  workshop_requests_as_apprentice workshop_request[] @relation("workshop_requests_as_apprentice")
  workshop_requests_as_mentor     workshop_request[] @relation("workshop_requests_as_mentor")

  feedback_as_mentor     mentor_feedback[] @relation("feedback_as_mentor")
  feedback_as_apprentice mentor_feedback[] @relation("feedback_as_apprentice")

  conversations_as_participant1 conversation[]       @relation("conversations_as_participant1")
  conversations_as_participant2 conversation[]       @relation("conversations_as_participant2")
  creditTransactions            credit_transaction[]
  supportRequests               support_request[]
  auditLogs                     audit_log[]
  workshops                     workshop[]
  messages                      message[]
  messageReactions              message_reaction[]
  notifications                 notification[]

  @@index([userId])
}

model credit_transaction {
  id          String                @id @default(cuid())
  appUserId   String
  amount      Int
  description String
  type        CreditTransactionType
  createdAt   DateTime              @default(now())

  app_user app_user @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@index([appUserId])
}

model support_request {
  id        String   @id @default(cuid())
  appUserId String
  subject   String
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  app_user app_user @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@index([appUserId])
}

model audit_log {
  id        String   @id @default(cuid())
  action    String
  adminId   String
  targetId  String?
  details   Json
  createdAt DateTime @default(now())

  admin app_user @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model user_report {
  id             String   @id @default(cuid())
  reporterUserId String
  reportedUserId String
  reason         String
  details        String?
  status         String   @default("PENDING") // PENDING, REVIEWED, DISMISSED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reporter app_user @relation(name: "reports_made", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reported app_user @relation(name: "reports_received", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reporterUserId])
  @@index([reportedUserId])
}

model user_block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker app_user @relation("blocked_by", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked app_user @relation("blocking", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model user_connection {
  id          String   @id @default(cuid())
  requesterId String
  receiverId  String
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester app_user @relation("sent_requests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  app_user @relation("received_requests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model workshop {
  id                         String    @id @default(cuid())
  creatorId                  String
  title                      String
  description                String?
  domain                     String?
  isPublished                Boolean   @default(false)
  maxParticipants            Int       @default(10)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  date                       DateTime?
  time                       String?
  duration                   Int?
  location                   String?
  isVirtual                  Boolean?
  apprenticeId               String?
  apprenticeAttendanceStatus String?

  creator         app_user          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  mentorFeedbacks mentor_feedback[]

  @@index([creatorId])
}

model workshop_request {
  id            String    @id @default(cuid())
  apprenticeId  String
  mentorId      String
  title         String
  description   String?
  message       String?
  preferredDate DateTime?
  preferredTime String?
  status        String    @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  apprentice app_user @relation("workshop_requests_as_apprentice", fields: [apprenticeId], references: [id], onDelete: Cascade)
  mentor     app_user @relation("workshop_requests_as_mentor", fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([apprenticeId])
  @@index([mentorId])
}

model mentor_feedback {
  id           String    @id @default(cuid())
  mentorId     String
  apprenticeId String
  workshopId   String
  rating       Int
  comment      String?
  isAnonymous  Boolean   @default(false)
  status       String    @default("ACTIVE") // ACTIVE, UNDER_REVIEW, DELETED
  reportedAt   DateTime?
  reportedBy   String?
  reportReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  mentor     app_user @relation("feedback_as_mentor", fields: [mentorId], references: [id], onDelete: Cascade)
  apprentice app_user @relation("feedback_as_apprentice", fields: [apprenticeId], references: [id], onDelete: Cascade)
  workshop   workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([apprenticeId])
  @@index([workshopId])
}

model conversation {
  id             String   @id @default(cuid())
  participant1Id String
  participant2Id String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participant1 app_user  @relation("conversations_as_participant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 app_user  @relation("conversations_as_participant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     message[]

  @@unique([participant1Id, participant2Id])
}

model message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       app_user     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  reactions message_reaction[]

  @@index([conversationId])
}

model message_reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    app_user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model notification {
  id        String   @id @default(cuid())
  userId    String
  senderId  String?
  type      String
  title     String
  message   String
  actionUrl String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user app_user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

enum CreditTransactionType {
  TOP_UP
  USAGE
  REFUND
}

enum FeedbackStatus {
  ACTIVE
  UNDER_REVIEW
  DELETED
}

model magic_link_token {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
