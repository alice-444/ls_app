{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Graphics --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "--- TECHNICAL METRICS ---",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 2 },
      "id": 1,
      "targets": [
        { "expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{route}} ({{status_code}})" }
      ],
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 2 },
      "id": 2,
      "targets": [
        { "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])", "legendFormat": "{{method}} {{route}}" }
      ],
      "title": "Average Request Duration",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 10 },
      "id": 101,
      "title": "--- BUSINESS METRICS ---",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "id": 5,
      "targets": [
        { "expr": "connected_users_total", "legendFormat": "{{role}}" }
      ],
      "title": "Connected Users by Role",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "id": 6,
      "targets": [
        { "expr": "increase(workshops_total[24h])", "legendFormat": "{{status}}" }
      ],
      "title": "Workshops Activity (Last 24h)",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "id": 7,
      "targets": [
        { "expr": "increase(credits_exchanged_total[24h])", "legendFormat": "{{type}}" }
      ],
      "title": "Credits Volume (Last 24h)",
      "type": "barchart"
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "--- SECURITY & RELIABILITY ---",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 8,
      "targets": [
        { "expr": "rate(auth_failures_total[5m])", "legendFormat": "{{reason}}" }
      ],
      "title": "Authentication Failures (Rate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 9,
      "targets": [
        { "expr": "rate(external_api_errors_total[5m])", "legendFormat": "{{service}}" }
      ],
      "title": "External API Errors (Rate)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "title": "LearnSup Full Monitoring",
  "uid": "ls_backend_full",
  "version": 2,
  "time": { "from": "now-6h", "to": "now" }
}
