  "scripts": {
    "dev": "concurrently \"pnpm run dev:socket\" \"pnpm run dev:next\"",
    "dev:socket": "tsx watch server.ts",
    "dev:next": "next dev --port 3001",
    "build": "next build",
    "start": "tsx server.ts",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
