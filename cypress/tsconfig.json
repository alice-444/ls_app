{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["cypress"],
    "typeRoots": ["../node_modules"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "rootDir": ".",
    "baseUrl": ".."
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
