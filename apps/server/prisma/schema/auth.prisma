model User {
  id              String    @id @map("_id")
  name            String
  username        String?   @unique
  email           String
  emailVerified   Boolean
  image           String?
  createdAt       DateTime
  updatedAt       DateTime
  // Soft disable / delete flags for defense-in-depth and compliance
  isDisabled      Boolean   @default(false)
  deletedAt       DateTime?
  displayUsername String?
  sessions        Session[]
  accounts        Account[]
  appUser         AppUser?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @map("_id")
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @map("_id")
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

enum Role {
  PROF
  APPRENANT
  ADMIN
}

enum AppUserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model AppUser {
  id                  String        @id @map("_id")
  userId              String        @unique
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                Role?
  status              AppUserStatus @default(PENDING)
  createdAt           DateTime
  updatedAt           DateTime
  // Soft delete metadata
  deletedAt           DateTime?
  deletionRequestedAt DateTime?
  deletionReason      String?
  // Prof profile fields
  bio                 String?
  domain              String?
  photoUrl            String?
  qualifications      String?
  experience          String?
  socialMediaLinks    Json?
  areasOfExpertise    Json?
  mentorshipTopics    Json?
  calendlyLink        String?
  isPublished         Boolean  @default(false)
  publishedAt         DateTime?
  // Relations
  workshops           Workshop[] @relation("CreatorWorkshops")
  apprenticeWorkshops Workshop[] @relation("ApprenticeWorkshops")
  // Feedbacks
  mentorFeedbacks     MentorFeedback[] @relation("MentorFeedbacks")
  apprenticeFeedbacks MentorFeedback[] @relation("ApprenticeFeedbacks")
  // Workshop Requests
  requestedWorkshops  WorkshopRequest[] @relation("ApprenticeRequests")
  receivedWorkshopRequests WorkshopRequest[] @relation("MentorRequests")
  
  @@map("app_user")
}

model AuditLog {
  id        String   @id @map("_id")
  userId    String
  type      String
  meta      Json?
  createdAt DateTime @default(now())

  @@map("audit_log")
}

model DeletionJob {
  id        String   @id @map("_id")
  userId    String
  runAt     DateTime
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runAt])
  @@map("deletion_job")
}

enum WorkshopStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum WorkshopRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model Workshop {
  id                String         @id @map("_id")
  title             String
  description       String?        
  date              DateTime?      
  time              String?        
  duration          Int?           
  location          String?
  isVirtual         Boolean        @default(false)
  maxParticipants   Int?
  materialsNeeded   String?
  status            WorkshopStatus @default(DRAFT)
  creatorId         String
  creator           AppUser        @relation("CreatorWorkshops", fields: [creatorId], references: [id], onDelete: Cascade)
  apprenticeId      String?         // Apprenti participant (pour ateliers confirmés depuis une demande)
  apprentice        AppUser?        @relation("ApprenticeWorkshops", fields: [apprenticeId], references: [id], onDelete: SetNull)
  requestId         String?         // Lien vers la demande d'atelier originale
  request           WorkshopRequest? @relation("WorkshopFromRequest", fields: [requestId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  publishedAt       DateTime?
  feedbacks         MentorFeedback[]

  @@index([creatorId])
  @@index([apprenticeId])
  @@index([status])
  @@index([requestId])
  @@map("workshop")
}

model MentorFeedback {
  id                String    @id @map("_id")
  mentorId          String
  mentor            AppUser   @relation("MentorFeedbacks", fields: [mentorId], references: [id], onDelete: Cascade)
  apprenticeId      String
  apprentice        AppUser   @relation("ApprenticeFeedbacks", fields: [apprenticeId], references: [id], onDelete: Cascade)
  workshopId       String?
  workshop          Workshop? @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  rating            Int       // 1-5 stars
  comment           String?
  isAnonymous       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([mentorId])
  @@index([apprenticeId])
  @@index([workshopId])
  @@index([createdAt])
  @@map("mentor_feedback")
}

model WorkshopRequest {
  id            String                @id @map("_id")
  title         String
  description   String?
  message       String?
  preferredDate DateTime?
  preferredTime String?
  status        WorkshopRequestStatus @default(PENDING)
  apprenticeId  String
  apprentice    AppUser               @relation("ApprenticeRequests", fields: [apprenticeId], references: [id], onDelete: Cascade)
  mentorId      String
  mentor        AppUser               @relation("MentorRequests", fields: [mentorId], references: [id], onDelete: Cascade)
  workshopId    String?               // Lien vers l'atelier créé quand la demande est acceptée
  workshop      Workshop?              @relation("WorkshopFromRequest")
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([apprenticeId])
  @@index([mentorId])
  @@index([status])
  @@index([createdAt])
  @@index([workshopId])
  @@map("workshop_request")
}
